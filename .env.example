# Flask Environment Configuration
# Options: development, production, testing
FLASK_ENV=production

# Cryptographic Secret Key for session signing
SECRET_KEY=generate_a_secure_random_key_here_for_production_signing

# SQLite Database name/path
DB_NAME=loveedit.db

# Redis connection string for high-performance caching (optional)
# Example: redis://localhost:6379/0
REDIS_URL=

# Port on which the application should run
PORT=9000

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Caching defaults (in seconds)
CACHE_DEFAULT_TIMEOUT=300

# Security and Rate Limiting
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
